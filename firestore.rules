rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isCoach() {
      return request.auth != null;
    }

    // Perfiles de clientas: lectura pública (link personal), escritura solo coach
    match /clients/{clientId} {
      allow read: if true;
      allow create, delete: if isCoach();
      allow update: if isCoach() || (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cycleStartedAt'])
        && request.resource.data.cycleStartedAt is string
      );
    }

    // Rutinas y nutrición: la clienta lee su plan; solo el coach edita
    match /routines/{docId} {
      allow read: if true;
      allow create, update, delete: if isCoach();
    }

    match /nutrition/{clientId} {
      allow read: if true;
      allow create, update, delete: if isCoach();
    }

    // Biblioteca: solo el coach (los GIFs se copian a la rutina)
    match /library-exercises/{exerciseId} {
      allow read, write: if isCoach();
    }

    // Historial: solo coach
    match /routineHistory/{entryId} {
      allow read, write: if isCoach();
    }

    match /nutritionHistory/{entryId} {
      allow read, write: if isCoach();
    }

    // Progreso: la clienta marca días desde su link (sin cuenta)
    match /weekProgress/{docId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isCoach();
    }

    match /progressCount/{clientId} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && request.resource.data.count <= 28;
      allow delete: if isCoach();
    }

    match /clientNotifications/{clientId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isCoach();
    }

    match /feedback/{feedbackId} {
      allow read: if isCoach();
      allow create: if request.resource.data.keys().hasAll(['clientId', 'clientName', 'rating', 'message', 'createdAt'])
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 500;
      allow update, delete: if isCoach();
    }
  }
}
