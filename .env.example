# Firebase (crear en console.firebase.google.com)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Coach: correos autorizados (coma-separados). Vacío = cualquier Auth (solo si desactivaste el registro).
# Debe coincidir con coachEmails() en firestore.rules cuando endurezcas la allowlist.
VITE_COACH_EMAILS=

# App Check — reCAPTCHA v3 site key (Firebase Console → App Check)
VITE_RECAPTCHA_SITE_KEY=

# El coach inicia sesión con Email/Password de Firebase Authentication
# (créalo en Authentication → Users). Desactiva el registro público.
# Ver SECURITY.md
